<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.osiris"
       name="Osiris Repository"
       version="1.0.0"
       provider-name="enkherdene">
    <extension point="xbmc.addon.repository" name="Osiris Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/enkherdene/kodi/main/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/enkherdene/kodi/main/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/enkherdene/kodi/main/zips</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Personal aggregated Kodi add-on repository</summary>
        <description lang="en_GB">Mirrors third-party Kodi add-ons from multiple external sources into a single installable repository, so only one repository source needs to be added on any Kodi installation.</description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <source>https://github.com/enkherdene/kodi</source>
    </extension>
</addon>
