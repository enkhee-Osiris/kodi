<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!-- Do not forget to bump the version above when changing the <dir> blocks
     below, to force clients already running an older repository.osiris to
     refresh and pick up the new tier definitions. -->
<addon id="repository.osiris"
       name="Osiris Repository"
       version="1.1.0"
       provider-name="enkhee-Osiris">
    <extension point="xbmc.addon.repository" name="Osiris Repository">
        <dir minversion="20.9.1" maxversion="21.9.0">
            <info compressed="false">https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips/tiers/omega/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips/tiers/omega/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips</datadir>
        </dir>
        <dir minversion="21.9.1">
            <info compressed="false">https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips/tiers/piers/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips/tiers/piers/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/enkhee-Osiris/kodi/main/zips</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Personal aggregated Kodi add-on repository</summary>
        <description lang="en_GB">Mirrors third-party Kodi add-ons from multiple external sources into a single installable repository, so only one repository source needs to be added on any Kodi installation.</description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <source>https://github.com/enkhee-Osiris/kodi</source>
    </extension>
</addon>
